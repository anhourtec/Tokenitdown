{
  "manifest_version": 3,
  "name": "TokenItDown",
  "version": "0.1.0",
  "description": "Capture any web page as a full-page screenshot.",
  "permissions": ["activeTab", "scripting", "storage", "debugger"],
  "host_permissions": [
    "http://localhost:3000/*",
    "https://tokenitdown.anhourtec.com/*"
  ],
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "Capture with TokenItDown",
    "default_icon": {
      "16": "src/icons/icon16.png",
      "32": "src/icons/icon32.png",
      "48": "src/icons/icon48.png",
      "128": "src/icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "src/service-worker.ts"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content-script.ts"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "src/icons/icon16.png",
    "32": "src/icons/icon32.png",
    "48": "src/icons/icon48.png",
    "128": "src/icons/icon128.png"
  }
}
