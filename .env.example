# Copy to .env and fill in. The .env file is read by:
#   - Next.js dev/build and the app (DATABASE_URL, BETTER_AUTH_*, REDIS_URL)
#   - docker-compose.yml on the server (POSTGRES_* and REDIS_PASSWORD)
#   - drizzle-kit and the db:* npm scripts (via --env-file-if-exists)
# Validation lives in env.mjs (T3 Env) — add new vars there too.
#
# Topology: ./deploy.sh builds + runs the FULL stack (web + Postgres + Redis)
# via docker-compose on 192.168.69.16. You can also run the app locally with
# `npm run dev` against the same DB. Ports differ from BookYourPTO-SaaS:
# Web 3020 (vs 3010) · Postgres 5433 (vs 5432) · Redis 6386 (vs 6385).
#
# NOTE: inside docker-compose the web container talks to `postgres:5432` /
# `redis:6379` (DATABASE_URL/REDIS_URL are overridden there from POSTGRES_* /
# REDIS_PASSWORD). The DATABASE_URL/REDIS_URL below are what the HOST uses
# (npm run dev, drizzle, db:* scripts).

# Enable the Next.js bundle analyzer during `npm run build` ("true" | "false").
ANALYZE=false

# --- App -> remote database/cache (used by next dev, drizzle, the app) ---
# Postgres connection string.
# Examples:
#   postgresql://tokenitdown:devpassword@localhost:5433/tokenitdown   - Host -> compose Postgres (published port)
#   postgresql://tokenitdown:devpassword@postgres:5432/tokenitdown    - Docker Compose internal (container name)
#   postgresql://tokenitdown:devpassword@192.168.69.16:5433/tokenitdown - Remote server over the LAN
#   postgresql://user:pass@db.example.com:5432/tokenitdown?sslmode=require - Managed Postgres with TLS
DATABASE_URL=postgresql://tokenitdown:devpassword@192.168.69.16:5433/tokenitdown
# Disable TLS for the LAN Postgres ("false"). Set "true" for a TLS-only server.
DB_SSL=false
# Optional for the auth baseline (sessions live in Postgres). Reserved for the
# job queue / future session store.
# Examples:
#   redis://localhost:6386                       - Host -> compose Redis (published port)
#   redis://localhost:6379/0                      - Local Redis, database 0
#   redis://:mypassword@localhost:6386            - Redis with password (no username)
#   redis://user:password@localhost:6386          - Redis with username & password
#   redis://redis:6379                            - Docker Compose internal (container name)
#   rediss://user:pass@redis.example.com:6380     - Redis with TLS (note: rediss://)
REDIS_URL=redis://:devredispass@192.168.69.16:6386

# --- Auth (better-auth) ---
# Generate a strong secret: `openssl rand -base64 32`
BETTER_AUTH_SECRET=replace-me-with-a-long-random-string
# Public base URL of the app — the browser origin MUST match this (CSRF / trusted
# origin). Local `npm run dev` -> http://localhost:3000. For the Docker deploy on
# the server, set this to the URL users hit, e.g. http://192.168.69.16:3020.
BETTER_AUTH_URL=http://localhost:3000
# Optional extra trusted origins (comma-separated) for better-auth, beyond
# BETTER_AUTH_URL. `npm run dev` auto-adds your LAN URL; set here for the Docker
# deploy if users reach it via multiple hosts. e.g. http://192.168.69.16:3020
# TRUSTED_ORIGINS=http://192.168.69.16:3020
# Optional: only set if the browser must reach a different origin than above.
# NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# --- docker-compose (server 192.168.69.16) credentials ---
# These provision the Postgres container and set the Redis password. Keep them
# in sync with DATABASE_URL / REDIS_URL above.
POSTGRES_USER=tokenitdown
POSTGRES_PASSWORD=devpassword
POSTGRES_DB=tokenitdown
REDIS_PASSWORD=devredispass

# Host port the web container is published on. Change if it clashes with another
# app on the server. MUST match the port in BETTER_AUTH_URL above (e.g. set
# BETTER_AUTH_URL=http://192.168.69.16:3030 when WEB_PORT=3030).
WEB_PORT=3030

# Skip env validation (used in CI builds). Leave unset locally.
# SKIP_ENV_VALIDATION=true
